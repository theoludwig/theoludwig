{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": ["node_modules/eslint-config-conventions/.oxlintrc.json"],
  "env": {
    "builtin": true,
    "browser": true,
    "node": true,
    "shared-node-browser": true
  },
  "rules": {
    "import/extensions": [
      "error",
      "ignorePackages",
      {
        "ts": "always",
        "tsx": "always",
        "js": "never",
        "jsx": "never"
      }
    ]
  }
}
